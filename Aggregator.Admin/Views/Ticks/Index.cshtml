@model IEnumerable<Aggregator.Admin.Models.Tick>

@{
    ViewData["Title"] = "Ticks";
}

<h2>Ticks</h2>

<div class="row mb-3">
    <div class="col-md-6">
        <button id="refreshBtn" class="btn btn-primary">Refresh</button>
    </div>
    <div class="col-md-6 text-end">
        <div class="form-inline">
            <label for="pageSizeSelect" class="me-2">Items per page:</label>
            <select id="pageSizeSelect" class="form-select" style="width: auto; display: inline-block;">
                <option value="25">25</option>
                <option value="50" selected>50</option>
                <option value="100">100</option>
                <option value="200">200</option>
            </select>
        </div>
    </div>
</div>

<div id="ticksTableContainer">
    <table class="table table-striped table-bordered" id="ticksTable">
        <thead class="table-dark">
            <tr>
                <th>Source</th>
                <th>Ticker</th>
                <th>Price</th>
                <th>Volume</th>
                <th>Timestamp</th>
            </tr>
        </thead>
        <tbody id="ticksBody">
            @foreach (var tick in Model)
            {
                <tr>
                    <td>@tick.Source</td>
                    <td>@tick.Ticker</td>
                    <td>@tick.Price</td>
                    <td>@tick.Volume</td>
                    <td>@tick.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function () {
        // Auto-refresh every 5 seconds
        var refreshInterval = setInterval(function () {
            refreshTicks();
        }, 5000);

        // Manual refresh button
        $('#refreshBtn').click(function () {
            refreshTicks();
        });

        // Page size change
        $('#pageSizeSelect').change(function () {
            refreshTicks();
        });

        function refreshTicks() {
            var pageSize = $('#pageSizeSelect').val();
            
            $.ajax({
                url: '/Ticks/GetTicks',
                type: 'GET',
                data: { pageSize: pageSize },
                success: function (data) {
                    var tbody = $('#ticksBody');
                    tbody.empty();
                    
                    $.each(data, function (index, tick) {
                        var row = '<tr>' +
                            '<td>' + tick.source + '</td>' +
                            '<td>' + tick.ticker + '</td>' +
                            '<td>' + tick.price + '</td>' +
                            '<td>' + tick.volume + '</td>' +
                            '<td>' + new Date(tick.timestamp).toLocaleString() + '</td>' +
                            '</tr>';
                        tbody.append(row);
                    });
                },
                error: function () {
                    console.log('Error refreshing ticks');
                }
            });
        }
    });
</script>