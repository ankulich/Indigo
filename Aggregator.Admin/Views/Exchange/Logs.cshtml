@model Aggregator.Admin.ExchangeSimulator.ExchangeServer

@{
    ViewData["Title"] = $"Logs - {Model.Name}";
}

<h2>Logs for @Model.Name</h2>

<div class="card">
    <div class="card-header">
        <h5>Server Information</h5>
    </div>
    <div class="card-body">
        <p><strong>Name:</strong> @Model.Name</p>
        <p><strong>Port:</strong> @Model.Port</p>
        <p><strong>Enabled:</strong> @(Model.Enabled ? "Yes" : "No")</p>
        <p><strong>Frequency:</strong> @Model.Frequency ms</p>
    </div>
</div>

<div class="card mt-3">
    <div class="card-header">
        <h5>Log Messages</h5>
    </div>
    <div class="card-body">
        <p>Log messages will appear here in real-time.</p>
        <p>Currently, this is a placeholder for the actual logging functionality.</p>
        <p>Logs are displayed in the console where the application is running.</p>
    </div>
</div>

<div class="mt-3">
    <a href="@Url.Action("Index", "Exchange")" class="btn btn-secondary">Back to Servers</a>
</div>
