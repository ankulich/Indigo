@model IEnumerable<Aggregator.Admin.ExchangeSimulator.ExchangeServer>

@{
    ViewData["Title"] = "Exchange Servers";
}

<h2>Exchange Servers</h2>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Port</th>
            <th>Enabled</th>
            <th>Frequency (ms)</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var server in Model)
    {
        <tr>
            <td>@server.Name</td>
            <td>@server.Port</td>
            <td>
                @if (server.Enabled)
                {
                    <span class="badge bg-success">Enabled</span>
                }
                else
                {
                    <span class="badge bg-secondary">Disabled</span>
                }
            </td>
            <td>@server.Frequency</td>
            <td>
                @if (server.Enabled)
                {
                    <a href="@Url.Action("Stop", "Exchange", new { name = server.Name })"
                       class="btn btn-danger btn-sm">
                        Stop
                    </a>
                }
                else
                {
                    <a href="@Url.Action("Start", "Exchange", new { name = server.Name })"
                       class="btn btn-success btn-sm">
                        Start
                    </a>
                }

                <a href="@Url.Action("Settings", "Exchange", new { name = server.Name })"
                   class="btn btn-warning btn-sm">
                    Settings
                </a>
                
                <a href="@Url.Action("Disconnect", "Exchange", new { name = server.Name })"
                   class="btn btn-secondary btn-sm">
                    Disconnect
                </a>
                
                <div class="btn-group" role="group">
                    <a href="@Url.Action("Resend", "Exchange", new { name = server.Name, count = 1 })"
                       class="btn btn-outline-primary btn-sm">
                        Resend 1x
                    </a>
                    <a href="@Url.Action("Resend", "Exchange", new { name = server.Name, count = 3 })"
                       class="btn btn-outline-primary btn-sm">
                        Resend 3x
                    </a>
                    <a href="@Url.Action("Resend", "Exchange", new { name = server.Name, count = 5 })"
                       class="btn btn-outline-primary btn-sm">
                        Resend 5x
                    </a>
                </div>
            </td>
        </tr>
    }
    </tbody>
</table>

<div class="mt-3">
    <a href="@Url.Action("Index", "Exchange")"
       class="btn btn-primary">
        Refresh
    </a>
</div>